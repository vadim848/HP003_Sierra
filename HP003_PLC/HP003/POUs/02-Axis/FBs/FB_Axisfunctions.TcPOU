    <Action Name="ReadParameters" Id="{651d82df-0559-40d1-90e7-a121d6c940b4}">
      <Implementation>
        <ST><![CDATA[CASE ReadParameterStep OF

	0:	IF NOT stAxFunctions^.ReadParametersInitialized
			AND stAxFunctions^.bAxisEnabled THEN
			McReadMaxVelo.Enable:=FALSE;
			McReadMotorInvertDir.Enable:=FALSE;
			McReadMinSoftLimitValue.Enable:=FALSE;
			McReadPosSoftLimitValue.Enable:=FALSE;
			McReadDefaultAcceleration.Enable:=FALSE;
			McReadDefaultDeceleration.Enable:=FALSE;
			McReadDefaultJerk.Enable:=FALSE;
			 stAxFunctions^.DriveReadParameterBusy:=TRUE;
			ReadDelay(IN:=FALSE);
			ReadParameterStep:=10;
		END_IF

	10:(*--------->McReadMaxVelo<---------------*)
		ReadDelay(IN:=TRUE,PT:=t#50ms);
		IF ReadDelay.Q THEN
			McReadMaxVelo.Enable:=TRUE;
			McReadMaxVelo.ParameterNumber:=eAxisMaxVelocity;
			McReadMaxVelo.ReadMode:=READMODE_ONCE;
	
			IF McReadMaxVelo.Busy THEN
				ReadDelay(IN:=FALSE);
				ReadParameterStep:=15;
			END_IF
		END_IF

	15:	IF NOT McReadMaxVelo.Busy THEN
			IF NOT McReadMaxVelo.Error THEN
				IF McReadMaxVelo.Valid THEN
					stAxFunctions^.McReadMaxVeloValidFiltered:=TRUE;
					stAxFunctions^.NCMaxVelo:=stAxFunctions^.NCMaxVeloRead;
				ELSE
					stAxFunctions^.McReadMaxVeloValidFiltered:=FALSE;
				END_IF
				McReadMaxVelo.Enable:=FALSE;
				ReadParameterStep:=20;
			ELSE
				McReadMaxVelo.Enable:=FALSE;
				ReadParameterStep:=10;
			END_IF
		END_IF


	20:(*--------->McReadMotorInvertDir<---------------*)
		ReadDelay(IN:=TRUE,PT:=t#50ms);
		IF ReadDelay.Q THEN
			McReadMotorInvertDir.Enable:=TRUE;
			McReadMotorInvertDir.ParameterNumber:=eAxisMotorDirectionInverse;
			McReadMotorInvertDir.ReadMode:=READMODE_ONCE;
			IF McReadMotorInvertDir.Busy THEN
				ReadDelay(IN:=FALSE);
				ReadParameterStep:=25;
			END_IF
		END_IF

	25:	IF NOT McReadMotorInvertDir.Busy THEN
			IF NOT McReadMotorInvertDir.Error THEN
				IF McReadMotorInvertDir.Valid THEN
					stAxFunctions^.McReadInvertMotorDirValidFiltered:=TRUE;
					stAxFunctions^.NCMotorInvertDir:=stAxFunctions^.NCMotorInvertDirRead;
				ELSE
					stAxFunctions^.McReadInvertMotorDirValidFiltered:=FALSE;
				END_IF
				McReadMotorInvertDir.Enable:=FALSE;
				ReadParameterStep:=50;
			ELSE
				McReadMotorInvertDir.Enable:=FALSE;
				ReadParameterStep:=20;
			END_IF
		END_IF


	50:(*--------->McReadMinSoftLimitValue<---------------*)
		ReadDelay(IN:=TRUE,PT:=t#50ms);
		IF ReadDelay.Q THEN
			McReadMinSoftLimitValue.Enable:=TRUE;
			McReadMinSoftLimitValue.ParameterNumber:=eAxisMinSoftPosLimit;
			McReadMinSoftLimitValue.ReadMode:=READMODE_ONCE;

			IF McReadMinSoftLimitValue.Busy THEN
				ReadDelay(IN:=FALSE);
				ReadParameterStep:=55;
			END_IF
		END_IF

	55:	IF NOT McReadMinSoftLimitValue.Busy THEN
			IF NOT McReadMinSoftLimitValue.Error THEN
				IF McReadMinSoftLimitValue.Valid THEN
					stAxFunctions^.McReadMinSoftLimitValueValidFiltered:=TRUE;
					stAxFunctions^.NCMinSoftLimitValue:=stAxFunctions^.NCMinSoftLimitValueRead;
				ELSE
					stAxFunctions^.McReadMinSoftLimitValueValidFiltered:=FALSE;
				END_IF
				McReadMinSoftLimitValue.Enable:=FALSE;
				ReadParameterStep:=60;
			ELSE
				McReadMinSoftLimitValue.Enable:=FALSE;
				ReadParameterStep:=50;
			END_IF
		END_IF


	60:(*--------->McReadPosSoftLimitValue<---------------*)
		ReadDelay(IN:=TRUE,PT:=t#50ms);
		IF ReadDelay.Q THEN
			McReadPosSoftLimitValue.Enable:=TRUE;
			 stAxFunctions^.DriveReadParameterBusy:=TRUE;
			McReadPosSoftLimitValue.ParameterNumber:=eAxisMaxSoftPosLimit;
			McReadPosSoftLimitValue.ReadMode:=READMODE_ONCE;
			IF McReadPosSoftLimitValue.Busy THEN
				ReadDelay(IN:=FALSE);
				ReadParameterStep:=65;
			END_IF
		END_IF


	65:	IF NOT McReadPosSoftLimitValue.Busy THEN
			IF NOT McReadPosSoftLimitValue.Error THEN
				IF McReadPosSoftLimitValue.Valid THEN
					stAxFunctions^.McReadPosSoftLimitValueValidFiltered:=TRUE;
					stAxFunctions^.NCPosSoftLimitValue:=stAxFunctions^.NCPosSoftLimitValueRead;
				ELSE
					stAxFunctions^.McReadPosSoftLimitValueValidFiltered:=FALSE;
				END_IF
				McReadPosSoftLimitValue.Enable:=FALSE;
				ReadParameterStep:=70;
			ELSE
				McReadPosSoftLimitValue.Enable:=FALSE;
				ReadParameterStep:=60;
			END_IF
		END_IF

	70:(*--------->McReadDefaultAcceleration<---------------*)
		ReadDelay(IN:=TRUE,PT:=t#50ms);
		IF ReadDelay.Q THEN
			McReadDefaultAcceleration.Enable:=TRUE;
			 stAxFunctions^.DriveReadParameterBusy:=TRUE;
			McReadDefaultAcceleration.ParameterNumber:=eAxisAcc;
			McReadDefaultAcceleration.ReadMode:=READMODE_ONCE;
			IF McReadDefaultAcceleration.Busy THEN
				ReadDelay(IN:=FALSE);
				ReadParameterStep:=75;
			END_IF
		END_IF


	75:	IF NOT McReadDefaultAcceleration.Busy THEN
			IF NOT McReadDefaultAcceleration.Error THEN
				IF McReadDefaultAcceleration.Valid THEN
					stAxFunctions^.McReadAccelerationDefaultValueValidFiltered:=TRUE;
					stAxFunctions^.NCAccelerationDefaultValue:=stAxFunctions^.NCAccelerationDefaultValueRead;
				ELSE
					stAxFunctions^.McReadAccelerationDefaultValueValidFiltered:=FALSE;
				END_IF
				McReadDefaultAcceleration.Enable:=FALSE;
				ReadParameterStep:=80;
			ELSE
				McReadDefaultAcceleration.Enable:=FALSE;
				ReadParameterStep:=70;
			END_IF
		END_IF


	80:(*--------->McReadDefaultDeceleration<---------------*)
		ReadDelay(IN:=TRUE,PT:=t#50ms);
		IF ReadDelay.Q THEN
			McReadDefaultDeceleration.Enable:=TRUE;
			stAxFunctions^.DriveReadParameterBusy:=TRUE;
			McReadDefaultDeceleration.ParameterNumber:=eAxisDec;
			McReadDefaultDeceleration.ReadMode:=READMODE_ONCE;
	
			IF McReadDefaultDeceleration.Busy THEN
				ReadDelay(IN:=FALSE);
				ReadParameterStep:=85;
			END_IF
		END_IF

	85:	IF NOT McReadDefaultDeceleration.Busy THEN
			IF NOT McReadDefaultDeceleration.Error THEN
				IF McReadDefaultDeceleration.Valid THEN
					stAxFunctions^.McReadDecelerationDefaultValueValidFiltered:=TRUE;
					stAxFunctions^.NCDecelerationDefaultValue:=stAxFunctions^.NCDecelerationDefaultValueRead;
				ELSE
					stAxFunctions^.McReadDecelerationDefaultValueValidFiltered:=FALSE;
				END_IF
				McReadDefaultDeceleration.Enable:=FALSE;
				ReadParameterStep:=90;
			ELSE
				McReadDefaultDeceleration.Enable:=FALSE;
				ReadParameterStep:=80;
			END_IF
		END_IF


	90:(*--------->McReadDefaultJerk<---------------*)
		ReadDelay(IN:=TRUE,PT:=t#50ms);
		IF ReadDelay.Q THEN
			McReadDefaultJerk.Enable:=TRUE;
			 stAxFunctions^.DriveReadParameterBusy:=TRUE;
	
			McReadDefaultJerk.ParameterNumber:=eAxisJerk;
			McReadDefaultJerk.ReadMode:=READMODE_ONCE;
	
			IF McReadDefaultJerk.Busy THEN
				ReadDelay(IN:=FALSE);
				ReadParameterStep:=95;
			END_IF
		END_IF

	95:	IF NOT McReadDefaultJerk.Busy THEN
			IF NOT McReadDefaultJerk.Error THEN
				IF McReadDefaultJerk.Valid THEN
					stAxFunctions^.McReadJerkDefaultValueValidFiltered:=TRUE;
					stAxFunctions^.NCJerkDefaultValue:=stAxFunctions^.NCJerkDefaultValueRead;
				ELSE
					stAxFunctions^.McReadJerkDefaultValueValidFiltered:=FALSE;
				END_IF
				McReadDefaultJerk.Enable:=FALSE;
				stAxFunctions^.ReadParametersInitialized:=TRUE;
				 stAxFunctions^.DriveReadParameterBusy:=FALSE;
				ReadParameterStep:=0;
			ELSE
				McReadDefaultJerk.Enable:=FALSE;
				ReadParameterStep:=90;
			END_IF
		END_IF

END_CASE



