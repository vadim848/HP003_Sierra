<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_Axis" Id="{bc990690-b581-413e-b58e-2a5ff921a80a}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Axis
(* 8888888888888888   SFC   8888888888888888888888*)
VAR_INPUT
	ResumeSFC             	: BOOL; 			(*	not automatic	*)
	ResetError            	: BOOL; 			(*	not automatic	*)
	fVelocity             	: LREAL := 20;
	sFB_Num				  	: STRING(3):='000'; // 3 digits for error list
	
	sFB_ModuleDescription 	: STRING(30):='';
	bPause				  	: BOOL;
	bReset				  	: BOOL;
	bModuloMode			  	: BOOL				:=FALSE;	
	eMotionType				: MC_MotionType		:=MC_MotionType.eAbsolute;
	eMotionDirection		: MC_Direction		:=MC_Direction.MC_Undefined_Direction;
	bTargetChanged			: BOOL;


END_VAR
VAR
	SFCCurrentStep      : STRING;
	SFCErrorPOU         : STRING;
	SFCErrorStep        : STRING;
	SFCError            : BOOL;
	SFCPause            : BOOL;
	SFCInit             : BOOL;
	SFCTipMode          : BOOL;
	SFCTip              : BOOL;
	SFCEnableLimit		: BOOL:=TRUE;
	// Reset Error
	SFCReset			: BOOL;
	ErrorSFC              : BOOL; 		(*	not automatic	*)
	Last_SFCErrorStep     : STRING; 	(*	not automatic	*)
	ErrorToPrint          : STRING; 	(*	not automatic	*)
	ton_SFCInit           : TON;
	ton_Disable           : TON;
	bMotionDone           : BOOL;
	ton_ResumeSFC_OffDelay: TON;
	sFB_ID                : STRING(4):='001';
	sActErrorID           : STRING(4);
	fbFormatString		  : FB_FORMATSTRING;
	sFullErrorId		  : STRING(12);//sAAAxBBBxEEE
	fb_SFC_Cycle		  : FB_SFC_Cycle;
	bNonPausedCycle: BOOL;
	rt_Resume: R_TRIG;

	iStepNo2: INT;
	iStepNo3: INT;
	ton_Delay: TON;
	bStepDone: BOOL;
	rt_TargetChanged: R_TRIG;
	op_Motor		: E_OperationButtons:=0;
END_VAR
(* 8888888888888888   END SFC   8888888888888888888888*)
VAR_INPUT
	bAutoDisable	: BOOL := FALSE;	(*	At not moving 30 sec	*)
	iAxisNum		: INT;
	fTollerance		: REAL:=0.1;
	fReference		: REAL:=0;
	bReadOffsetParameter   : BOOL;
	bWriteOffsetParameter  : BOOL;
	bSetZeroPB             : BOOL;
	fActPosSetToZero       : LREAL;
	
END_VAR
VAR_IN_OUT
	stOperation		: ST_OperationButtons;
	Points			: ST_AxisPoints;
	iTarget			: INT;
	iSubTarget		: INT;
END_VAR



VAR
	Shelf: INT;
	i				: INT;
	k				: INT;
	c_InPos			: INT;
	iLastTarget		: INT;
	iLastSubTarget	: INT;
	fLastPosition	: REAL;
	//sFB_Num         : STRING(3):='000';
	
	fbReadWrite_NC_PB  :FB_ReadWrite_NC_PB;
	iStepNo: INT;

END_VAR

VAR_OUTPUT
	fReadeToEncoderOffset  : LREAL;
END_VAR

VAR CONSTANT
	iStartPoint		: INT:=1;
	iPointNum		: INT:=15;
	iStartSubPoint	: INT:=-2;
	iSubPointNum	: INT:=2;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[op_Motor:=stOperation.iActOperation;
act_InPosCalc();
act_GetErrorID();
act_Oper();
act_ReadWrite_NC_PB();
ton_ResumeSFC_OffDelay(PT:=T#0.1S);
rt_Resume(CLK:=stOperation.iActOperation=E_OperationButtons.ePlayAll);
rt_TargetChanged(CLK:=bTargetChanged);
IF rt_Resume.Q  THEN
	ton_ResumeSFC_OffDelay.IN:=TRUE;
END_IF
IF ton_ResumeSFC_OffDelay.Q THEN
	ton_ResumeSFC_OffDelay.IN:=FALSE;
	bNonPausedCycle:=FALSE;
	SFCPause:=FALSE;
	SFCError:=FALSE;
END_IF
IF stOperation.bStopResetAll THEN;
	stAxesfunctions[iAxisNum].bMcHalt:=FALSE;
	iSubTarget:=0;
	iTarget:=0;
END_IF
fb_SFC_Cycle
(
	sCycleName:= 'Axis Control', 
	bSFCError:=SFCError , //
	sSFCCurrentStep:=SFCCurrentStep , 
	sSFCErrorStep:= SFCErrorStep, 
	sSFCErrorPOU:=SFCErrorPOU , 
	sActErrorID:=sFullErrorId,
	//sFB_ModuleDescription:= CONCAT(sFB_ModuleDescription,INT_TO_STRING(iFB_Num)), 
	sFB_ModuleDescription:= sFB_ModuleDescription, 
	sLast_SFCErrorStep=>Last_SFCErrorStep , 
	bErrorSFC_Occured=> ErrorSFC, 
	//sErrorToPrint=>ErrorToPrint ,
	//sLast_ErrorToPrint=>, 
	bSFCInit=>SFCInit , 
	stOperation:=stOperation ,
	bResumeSFC:=ResumeSFC , 
	bResetError:=ResetError , 
	bSFCPause:=bNonPausedCycle,// SFCPause, bNonPausedCycle
	bResetCycle:=SFCReset
);


(*act_Locations;*)

ton_Disable(	PT:=T#30S,
			IN:=bAutoDisable
			AND stAxis[iAxisNum].Status.NotMoving
			AND stAxesfunctions[iAxisNum].McPowerState
			AND NOT stAxis[iAxisNum].Status.Disabled);
			
]]></ST>
    </Implementation>
    <Folder Name="Actions" Id="{19a40766-b7eb-4c73-a4d3-090adc0dc6ee}" />
    <Folder Name="Trans" Id="{2a0730e9-7a28-47d9-8b64-35e038d1884f}" />
    <Action Name="act_GetErrorID" Id="{c7fcb077-28ef-481e-8b12-2903faa42a79}">
      <Implementation>
        <ST><![CDATA[IF ErrorSFC THEN;
	// Initialization
	IF    Last_SFCErrorStep='MotorPowerNotOK' 		THEN sActErrorID:='001';
	ELSIF Last_SFCErrorStep='WatingMotionDone' 	    THEN sActErrorID:='002';
	ELSIF Last_SFCErrorStep='InPosCheck_1' 		    THEN sActErrorID:='003';
	ELSIF Last_SFCErrorStep='LimitDetected'         THEN sActErrorID:='004';
	ELSIF Last_SFCErrorStep='StopAxis'         		THEN sActErrorID:='005';	
	ELSE
		 sActErrorID:='999';
	END_IF
	
//ELSIF bWarning THEN;
	// Leave the warning message to print
ELSE;
		 sActErrorID:='000';
END_IF




fbFormatString(
	sFormat:= '%.3sx%.3sx%.3s', 
	arg1:= F_STRINGEx(sFB_ID), 
	arg2:= F_STRINGEx(sFB_Num), 
	arg3:= F_STRINGEx(sActErrorID), 
	sOut=>sFullErrorId );
	
//(*Clean Last ErrID*)IF NOT SFCPause AND NOT ErrorSFC THEN	sFullErrorId:='';END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="act_InPosCalc" Id="{6d22facd-de77-446f-8756-a5b8b563146e}">
      <Implementation>
        <ST><![CDATA[;
k:=0;
FOR i:=iStartPoint TO iPointNum DO
	FOR k:=iStartSubPoint TO iSubPointNum DO
		Points.arInPos[i,k]:=FALSE;
	END_FOR
END_FOR


FOR i:=iStartPoint TO iPointNum DO
	FOR k:=iStartSubPoint TO iSubPointNum DO
		IF 	(NOT bModuloMode)
		AND eMotionType=MC_MotionType.eAbsolute
		AND stAxis[iAxisNum].NcToPlc.ActPos > Points.arPos[i,k]-fTollerance
		AND stAxis[iAxisNum].NcToPlc.ActPos < Points.arPos[i,k]+fTollerance
		AND stAxis[iAxisNum].Status.NotMoving
		(*AND stAxis[iAxisNum].Status.StandStill*)
		AND stAxis[iAxisNum].Status.InTargetPosition	THEN
			Points.arInPos[i,k]:=TRUE;
		ELSIF bModuloMode
		AND eMotionType=MC_MotionType.eAbsolute
		AND stAxis[iAxisNum].NcToPlc.ModuloActPos > Points.arPos[i,k]-fTollerance
		AND stAxis[iAxisNum].NcToPlc.ModuloActPos < Points.arPos[i,k]+fTollerance
		AND stAxis[iAxisNum].Status.NotMoving
		(*AND stAxis[iAxisNum].Status.StandStill*)
		AND stAxis[iAxisNum].Status.InTargetPosition	THEN
			Points.arInPos[i,k]:=TRUE;			
		END_IF
	END_FOR
END_FOR


c_InPos:=0;
FOR i:=iStartPoint TO iPointNum DO
	FOR k:=iStartSubPoint TO iSubPointNum DO
		IF Points.arInPos[i,k] THEN
			c_InPos:=c_InPos+1;
		END_IF
	END_FOR
END_FOR]]></ST>
      </Implementation>
    </Action>
