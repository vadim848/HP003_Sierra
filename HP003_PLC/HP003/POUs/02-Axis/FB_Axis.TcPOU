    <Action Name="act_ReadWrite_NC_PB" Id="{77dcfb9e-0415-4be2-a549-f01ba5e38427}">
      <Implementation>
        <ST><![CDATA[ton_Delay();
IF iAxisNum>0 AND iAxisNum<=C_Max_AxesCount THEN;
	fbReadWrite_NC_PB
	(
		bReadParameter:= , 
		bWriteParameter:= , 	
		iAxisNum:=iAxisNum , 
		mcAxisParameter:=MC_AxisParameter.AxisEncoderOffset , 	 
		bReatBusy=> , 
		bWriteBusy=> , 
		bReatError=> , 
		bWriteError=> ,
		fReadEncoderOffset=>,
		fWriteEncoderOffset:=ar_AxisPos_BIOS[iAxisNum]		
		);


	IF bReadOffsetParameter THEN
			CASE iStepNo OF
			0:
			  fbReadWrite_NC_PB.iAxisNum := iAxisNum ;
			  fReadeToEncoderOffset:=0;
			  iStepNo :=10;
			  
		   10:
			  IF NOT fbReadWrite_NC_PB.bReatBusy AND NOT fbReadWrite_NC_PB.bReatError THEN
				 fbReadWrite_NC_PB.bReadParameter := TRUE;
				 iStepNo :=20;
			  END_IF
			  
		   20:
			 IF fbReadWrite_NC_PB.bReatBusy AND NOT fbReadWrite_NC_PB.bReatError THEN
				fbReadWrite_NC_PB.bReadParameter := FALSE;
				iStepNo :=30; 
			   END_IF
			   
			30:
			   fReadeToEncoderOffset:= fbReadWrite_NC_PB.fReadEncoderOffset;
			   ar_AxisPos_BIOS[iAxisNum]:= fbReadWrite_NC_PB.fReadEncoderOffset;
			   bReadOffsetParameter := FALSE;
			   iStepNo :=0;
	
			END_CASE
	END_IF
	
	(*********************** Write Offset *************************)
	
	IF bWriteOffsetParameter THEN
			CASE iStepNo2 OF
				
			0:
			  fbReadWrite_NC_PB.iAxisNum := iAxisNum ;
			  stAxesfunctions[iAxisNum].bMcPower:=FALSE;
			  ton_Delay.PT:=T#0.5S;ton_Delay.IN:=TRUE;			  
			  iStepNo2 :=5;
			5:IF ton_Delay.Q THEN;
				 iStepNo2 :=10;
				 ton_Delay.IN:=FALSE;
			  END_IF
			  
		   10:
			  IF NOT fbReadWrite_NC_PB.bWriteBusy AND NOT fbReadWrite_NC_PB.bWriteError THEN
				 fbReadWrite_NC_PB.bWriteParameter := TRUE;
				 iStepNo2 :=20;
			  END_IF
			  
		   20:
			 IF fbReadWrite_NC_PB.bWriteBusy AND NOT fbReadWrite_NC_PB.bWriteError THEN
				fbReadWrite_NC_PB.bWriteParameter := FALSE;
				iStepNo2 :=30; 
			   END_IF
			   
			30:
			   bWriteOffsetParameter  := FALSE;
			   bReadOffsetParameter:=TRUE;
			   iStepNo2 :=0;
			END_CASE
	END_IF
	
	
	
	(************************* Set Zero ****************************)
	
	IF bSetZeroPB THEN
		CASE iStepNo3 OF
			
		   0:
			 fActPosSetToZero := stAxis[iAxisNum].NcToPlc.ActPos - fReadeToEncoderOffset;
			 ar_AxisPos_BIOS[iAxisNum] := fActPosSetToZero * -1;
			 iStepNo3 :=10;
		  10:
			 bWriteOffsetParameter := TRUE;
			 iStepNo3 :=20;
		  20:
			 bSetZeroPB := FALSE;
			 iStepNo3 :=0;
	
		END_CASE
	END_IF

END_IF


 

]]></ST>
      </Implementation>
    </Action>
    <Transition Name="ConToExit_" Id="{8b0a15dd-fd97-405f-a3c0-8e30f6d5a021}" FolderPath="Trans\">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNum].McHaltDone
OR
stAxesfunctions[iAxisNum].McStopDone
OR
(NOT stAxis[iAxisNum].Status.Stopping)]]></ST>
      </Implementation>
    </Transition>
    <Action Name="Enable_Entry" Id="{790b1e52-2418-455b-bed0-0ee6632b9fc4}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNum].bMcPower:=TRUE;]]></ST>
      </Implementation>
    </Action>
    <Transition Name="EnableOK_" Id="{20fbcc47-66f5-4dd2-8a34-87b816e9331c}" FolderPath="Trans\">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNum].McPowerState
AND
stAxesfunctions[iAxisNum].bAxReleaseNeg
AND
stAxesfunctions[iAxisNum].bAxReleasePos]]></ST>
      </Implementation>
    </Transition>
    <Action Name="GoToTargetAbs_1_active" Id="{ea89b8ee-7b6d-4e1a-87c8-1fd9e51c12ad}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[IF iTarget<>0 AND iTarget<=iPointNum AND iTarget>=iStartPoint THEN
	stAxesfunctions[iAxisNum].fPosition:=Points.arPos[iTarget,iSubTarget];
	fLastPosition:=Points.arPos[iTarget,iSubTarget];
	iLastTarget:=iTarget;
	iLastSubTarget:=iSubTarget;
END_IF

IF stAxesfunctions[iAxisNum].fPosition=Points.arPos[iTarget,iSubTarget] THEN
	stAxesfunctions[iAxisNum].fVelocity:=fVelocity;
	stAxesfunctions[iAxisNum].bMcMoveAbs:=TRUE;
	stAxesfunctions[iAxisNum].bMcHalt:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="GoToTargetAbs_2_active" Id="{8e292382-54f4-4305-b635-89f6c9bf316a}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[IF iTarget<>0 AND iTarget<=iPointNum AND iTarget>=iStartPoint THEN
	stAxesfunctions[iAxisNum].fPosition:=Points.arPos[iTarget,iSubTarget];
	fLastPosition:=Points.arPos[iTarget,iSubTarget];
	iLastTarget:=iTarget;
	iLastSubTarget:=iSubTarget;
END_IF

IF stAxesfunctions[iAxisNum].fPosition=Points.arPos[iTarget,iSubTarget] THEN
	stAxesfunctions[iAxisNum].fVelocity:=fVelocity;
	stAxesfunctions[iAxisNum].iDirection:=eMotionDirection;
	stAxesfunctions[iAxisNum].bMcHalt:=FALSE;		
	IF eMotionDirection=MC_Direction.MC_Positive_Direction OR eMotionDirection=MC_Direction.MC_Negative_Direction THEN;
		IF ABS(stAxesfunctions[iAxisNum].fPosition-stAxis[iAxisNum].NcToPlc.ModuloActPos)<30
		OR ABS(stAxesfunctions[iAxisNum].fPosition-stAxis[iAxisNum].NcToPlc.ModuloActPos)>330
		THEN;
			stAxesfunctions[iAxisNum].iDirection:=MC_Direction.MC_Shortest_Way;
			stAxesfunctions[iAxisNum].bMcMoveModulo:=TRUE;
			bStepDone:=TRUE;
		ELSE;
			stAxesfunctions[iAxisNum].bMcMoveModulo:=TRUE;
			bStepDone:=TRUE;
		END_IF
	ELSIF eMotionDirection=MC_Direction.MC_Shortest_Way THEN;
		stAxesfunctions[iAxisNum].bMcMoveModulo:=TRUE;
		bStepDone:=TRUE;
	ELSE
		bStepDone:=FALSE;		
	END_IF
ELSE
	bStepDone:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="GoToTargetRelative_1_active" Id="{ea19668a-110a-47a6-b5fe-b463696d0577}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Action>
    <Action Name="GoToTargetRelative_2_active" Id="{d4de4710-f997-4e2f-9dd5-20d939f59bf5}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Action>
    <Action Name="Halt_Entry" Id="{c3e8f353-c31d-4843-a7cd-1d8d8574a80a}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[	stAxesfunctions[iAxisNum].bMcMoveAbs:=FALSE;
	stAxesfunctions[iAxisNum].bMcMoveRel:=FALSE;
	stAxesfunctions[iAxisNum].bMcMoveModulo:=FALSE;
	stAxesfunctions[iAxisNum].bMcHalt:=TRUE;
	iTarget:=0;]]></ST>
      </Implementation>
    </Action>
    <Action Name="HaltDone_Action" Id="{ae5f33e7-5ac6-4693-be48-25885c105c7b}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[IF 	stAxesfunctions[iAxisNum].McHaltErr THEN
	stAxesfunctions[iAxisNum].bMcStop:=TRUE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="Init_Action" Id="{0157bdc7-0271-4a2c-8c9d-e1bd1ae3210d}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNum].bMcMoveAbs:=FALSE;
stAxesfunctions[iAxisNum].bMcMoveRel:=FALSE;
stAxesfunctions[iAxisNum].bMcMoveModulo:=FALSE;
//stAxesfunctions[iAxisNum].bMcHalt:=FALSE;
stAxesfunctions[iAxisNum].fAcceleration:=0;
stAxesfunctions[iAxisNum].fDeceleration:=0;
stAxesfunctions[iAxisNum].fJerk:=0;
SFCReset:=FALSE;
bTargetChanged:=FALSE;]]></ST>
      </Implementation>
    </Action>
    <Action Name="InPosCheck_1_Action" Id="{61d4f6ab-80ff-4a16-a37e-d964c49bb924}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[IF iTarget >=iStartPoint AND iTarget<=iPointNum THEN
	IF Points.arInPos[iTarget,iSubTarget]
	AND stAxis[iAxisNum].Status.InTargetPosition
	//AND stAxesfunctions[iAxisNum].McMoveAbsoluteDone  
	THEN;
		iTarget:=eDone;
		iSubTarget:=eDone;
	END_IF
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="InPosCheck_1_Exit" Id="{512f78aa-a2dd-4891-a218-c5d498886451}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNum].bMcMoveAbs:=FALSE;
stAxesfunctions[iAxisNum].bMcMoveRel:=FALSE;
stAxesfunctions[iAxisNum].bMcMoveModulo:=FALSE;
//bMotionDone:=TRUE;]]></ST>
      </Implementation>
    </Action>
    <Transition Name="LimitConCheck_" Id="{cb06290a-35e6-4fa6-beae-cc0811043341}" FolderPath="Trans\">
      <Implementation>
        <ST><![CDATA[NOT stAxesfunctions[iAxisNum].McPowerState
OR
NOT stAxesfunctions[iAxisNum].bAxReleaseNeg
OR
NOT stAxesfunctions[iAxisNum].bAxReleasePos]]></ST>
      </Implementation>
    </Transition>
    <Action Name="LimitDetected_Exit" Id="{9f8cda0c-d447-4fdd-8f3c-b5a5758479af}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[SFCReset:=TRUE;]]></ST>
      </Implementation>
    </Action>
    <Transition Name="NoReq_" Id="{3b8d3037-1ce0-4f71-af7f-e5253891fcd7}" FolderPath="Trans\">
      <Implementation>
        <ST><![CDATA[iTarget=eDone]]></ST>
      </Implementation>
    </Transition>
    <Transition Name="NoReq__1" Id="{cf1ef19d-8947-4bcf-a011-68504d3c686c}" FolderPath="Trans\">
      <Implementation>
        <ST><![CDATA[iTarget=eDone]]></ST>
      </Implementation>
    </Transition>
    <Action Name="Power_Off_Action" Id="{654f985a-7d1b-422b-853d-e51d54419cf3}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[IF NOT stAxis[iAxisNum].Status.NotMoving THEN
	stAxesfunctions[iAxisNum].bMcPower:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="Ready_Action" Id="{026512fd-0aaf-4545-803f-f74333f2b32f}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[IF 	stAxesfunctions[iAxisNum].bMcHalt AND op_Motor=E_OperationButtons.ePlayAll THEN;
	iSubTarget:=iLastSubTarget;
	iTarget:=iLastTarget;
END_IF


IF ton_Disable.Q THEN
	stAxesfunctions[iAxisNum].bMcPower:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="Ready_Exit" Id="{92c55298-2029-4089-a970-94edeb495178}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[bMotionDone:=FALSE;
stAxesfunctions[iAxisNum].bMcStop:=FALSE;]]></ST>
      </Implementation>
    </Action>
    <Transition Name="StartCon_" Id="{02d178bf-84be-46a4-b531-c86bc3ffb92d}" FolderPath="Trans\">
      <Implementation>
        <ST><![CDATA[NOT stAxesfunctions[iAxisNum].McMoveAbsoluteDone
AND
NOT stAxesfunctions[iAxisNum].bMcMoveAbs]]></ST>
      </Implementation>
    </Transition>
    <Action Name="StopAxis_1_active" Id="{90eafc07-383d-458e-bf5b-b6eb07e01600}">
      <Implementation>
        <ST><![CDATA[IF stAxesfunctions[iAxisNum].McStopDone THEN;
	bStepDone:=TRUE;
ELSE;
	bStepDone:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="StopAxis_1_entry" Id="{34dda2c1-f9e9-4fce-8c49-6f0779e596c9}">
      <Implementation>
        <ST><![CDATA[	stAxesfunctions[iAxisNum].bMcMoveAbs:=FALSE;
	stAxesfunctions[iAxisNum].bMcMoveRel:=FALSE;
	stAxesfunctions[iAxisNum].bMcMoveModulo:=FALSE;
	
	stAxesfunctions[iAxisNum].bMcStop:=TRUE;]]></ST>
      </Implementation>
    </Action>
    <Action Name="StopAxis_1_exit" Id="{642e680b-77ff-468b-b48d-448b34bdc2ab}">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNum].bMcStop:=FALSE;]]></ST>
      </Implementation>
    </Action>
    <Action Name="WatingMotionDone_active" Id="{9e0deedb-8a54-4f99-a3a2-857490ae2ee2}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[bMotionDone:=FALSE;
IF bModuloMode THEN;
	IF eMotionType=MC_MotionType.eAbsolute
	AND stAxesfunctions[iAxisNum].McMoveModuloDone
	THEN;
		bMotionDone:=TRUE;
	ELSIF eMotionType=MC_MotionType.eRelative 
	AND FALSE	
	THEN;
		bMotionDone:=TRUE;
	ELSE;
		bMotionDone:=FALSE;
	END_IF
ELSE;
	IF eMotionType=MC_MotionType.eAbsolute 
	AND stAxesfunctions[iAxisNum].McMoveAbsoluteDone
	THEN;
		bMotionDone:=TRUE;
	ELSIF eMotionType=MC_MotionType.eRelative
 	AND FALSE
	THEN;
		bMotionDone:=TRUE;
	ELSE;
		bMotionDone:=FALSE;
	END_IF	
END_IF]]></ST>
      </Implementation>
    </Action>
