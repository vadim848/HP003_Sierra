<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_DeadStopHomming" Id="{6e5e5dde-9ebb-4284-b5aa-00747ca031a1}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_DeadStopHomming
VAR_INPUT
	bExecute      : BOOL;
	iVelocute     : INT := 1;
	fRangeToChek : REAL;  //[mm]
	//bDirection    : BOOL; //[Positive or negative]
	iEndPosition  : REAL; //[mm]
	iAxisNumber   : INT;
	
	fHomingPositionOffset : REAL:=1; //[mm]
	
	
	ResumeSFC :BOOL; 			(*	not automatic	*)
	ResetError:BOOL; 			(*	not automatic	*)
	
//	pstOperation  : POINTER TO ST_OperationButtons;
//	pTarget		  : POINTER TO ARRAY[1..13] OF INT;
//	pSubTarget	  : POINTER TO ARRAY[1..13] OF INT;
	p_arr_Axis	  : POINTER TO ARRAY[1..13] OF ST_AxisPoints;
END_VAR
VAR_OUTPUT
	bHommingDone  : BOOL;
END_VAR
VAR
	iCount              : INT;
	fb_SFC_Cycle		: FB_SFC_Cycle;
	fbMC_Home           : MC_Home;
	
	
	SFCCurrentStep      : STRING;
	SFCErrorPOU         : STRING;
	SFCErrorStep        : STRING;
	SFCError            : BOOL;
	SFCPause            : BOOL;
	SFCInit             : BOOL;
	SFCTipMode          : BOOL;
	SFCTip              : BOOL;
	SFCEnableLimit		: BOOL:=TRUE;
	// Reset Error
	SFCReset			  : BOOL;
	ErrorSFC              : BOOL; 		(*	not automatic	*)
	Last_SFCErrorStep     : STRING; 	(*	not automatic	*)
	//ErrorToPrint          : STRING; 	(*	not automatic	*)
	//Last_ErrorToPrint     : STRING; 	(*	not automatic	*)
	sFullErrorId		  : STRING(12);//sAAAxBBBxEEE
	
	iFB_Num : INT ;
	iCount2: INT;
	bStepDone: BOOL;
	
	fbEcCoESdoWrite			:FB_EcCoESdoWrite;
	fbEcCoESdoRead			:FB_EcCoESdoRead;	
	
	EL7037AdrInfo AT %I* 	:AMSADDR;
	pWriteMaxCurrent: POINTER TO INT;
	pReadMaxCurrent: POINTER TO INT;
	
	iMaxCurrent				: INT :=1500;
	iReducedCurrent			: INT :=800; 
	iMaxCurrentToWrite		: INT;
	iMaxCurrent_FB			: INT;

	bReduceCurrent: BOOL;	
END_VAR
VAR_IN_OUT
	stOperation  			: ST_OperationButtons;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[act_Oper();

fb_SFC_Cycle(
	//pstOperation:=pstOperation , 
	sCycleName:= 'Dead Stop Homming', 
	bSFCError:=SFCError , 
	sSFCCurrentStep:=SFCCurrentStep , 
	sSFCErrorStep:= SFCErrorStep, 
	sSFCErrorPOU:= SFCErrorPOU, 
	sActErrorID:=sFullErrorId , 
	iFB_Num:= 113, 
	sFB_ModuleDescription:=fb_SFC_Cycle.sCycleName , 
	sLast_SFCErrorStep=>Last_SFCErrorStep , 
	bErrorSFC_Occured=>ErrorSFC , 
	//sErrorToPrint=>ErrorToPrint , 
	//sLast_ErrorToPrint=>Last_ErrorToPrint , 
	bSFCInit=>SFCInit ,
 	stOperation:=stOperation ,
	bResumeSFC:=ResumeSFC , 
	bResetError:=ResetError , 
	bSFCPause:=SFCPause , 
	bResetCycle:= SFCReset);

fbMC_Home(
	Axis:=stAxis[iAxisNumber] , 
	Execute:= , 
	Position:=fHomingPositionOffset , 
	HomingMode:=MC_Direct , 
	BufferMode:= , 
	Options:= , 
	bCalibrationCam:= , 
	Done=> , 
	Busy=> , 
	Active=> , 
	CommandAborted=> , 
	Error=> , 
	ErrorID=> );
]]></ST>
    </Implementation>
