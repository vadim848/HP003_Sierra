      </Implementation>
    </Transition>
    <Action Name="ReduceTurque_active" Id="{0e09f7cd-88a2-4598-9ddc-db62b341fa71}">
      <Implementation>
        <ST><![CDATA[
fbEcCoESdoWrite(
	sNetId:=F_CreateAmsNetId(EL7037AdrInfo.netId) , 
	nSlaveAddr:=EL7037AdrInfo.port , 
	nSubIndex:=16#0001 , 
	nIndex:=16#8010 , 
	pSrcBuf:=ADR(iReducedCurrent) , 
	cbBufLen:=2 , 
	bExecute:=TRUE , 
	tTimeout:= , 
	bBusy=> , 
	bError=> , 
	nErrId=> );]]></ST>
      </Implementation>
    </Action>
