]]></ST>
      </Implementation>
    </Action>
    <Transition Name="TheRequiredPoint" Id="{fc910ae6-905b-472a-8b3a-29868f54bc6d}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[
ABS(stAxesfunctions[iAxisNumber].PFB)<=iEndPosition+0.2
AND 
ABS(stAxesfunctions[iAxisNumber].PFB)>=iEndPosition-0.2]]></ST>
      </Implementation>
    </Transition>
    <Transition Name="TheRequiredPointFailed" Id="{bd94fc9a-e12b-4199-a520-4358f974fa65}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[abs(stAxesfunctions[iAxisNumber].PFB)<>iEndPosition;]]></ST>
      </Implementation>
    </Transition>
