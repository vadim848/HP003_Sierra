    <Action Name="act_ReduceCurrent" Id="{7ecbea75-06b1-4369-b6e9-b9a69b1af0bb}">
      <Implementation>
        <ST><![CDATA[

IF bReduceCurrent THEN;
	iMaxCurrentToWrite:=iReducedCurrent;
ELSE;
	iMaxCurrentToWrite:=iMaxCurrent;
END_IF



fbEcCoESdoWrite(
	sNetId:=F_CreateAmsNetId(EL7037AdrInfo.netId) , 
	nSlaveAddr:=EL7037AdrInfo.port , 
	nSubIndex:=16#0001 , 
	nIndex:=16#8010 , 
	pSrcBuf:=ADR(iMaxCurrentToWrite) , 
	cbBufLen:=2 , 
	bExecute:= , 
	tTimeout:= , 
	bBusy=> , 
	bError=> , 
	nErrId=> );

(*fbEcCoESdoRead(
	sNetId:=F_CreateAmsNetId(EL7037AdrInfo.netId) , 
	nSlaveAddr:=EL7037AdrInfo.port , 
	nSubIndex:=16#0001 , 
	nIndex:=16#8010 , 
	pDstBuf:=ADR(iMaxCurrent_FB) , 
	cbBufLen:=2 , 
	bExecute:= , 
	tTimeout:= , 
	bBusy=> , 
	bError=> , 
	nErrId=> , 
	cbRead=> );*)
	]]></ST>
      </Implementation>
    </Action>
    <Action Name="CheckPos_active" Id="{7ceaf36c-758d-4d8d-9f36-8d9a973c0abb}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[IF ABS(stAxesfunctions[iAxisNumber].PFB)<fHomingPositionOffset+0.1
AND ABS(stAxesfunctions[iAxisNumber].PFB)>fHomingPositionOffset-0.1 THEN;
	bStepDone:=TRUE;
ELSE;
	bStepDone:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="CheckPos_EndRange_active" Id="{b6461f35-4266-433f-bd8a-0666cbc36d16}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[IF stAxesfunctions[iAxisNumber].PFB<=fRangeToChek+fHomingPositionOffset+0.01
AND stAxesfunctions[iAxisNumber].PFB>=fRangeToChek+fHomingPositionOffset-0.01 THEN;
	bStepDone:=TRUE;
ELSE;
	bStepDone:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="count_entry" Id="{87eac5ad-617b-465e-84af-40b78e8c26ca}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[iCount:=iCount+1;
fbMC_Home.Execute:=false;]]></ST>
      </Implementation>
    </Action>
    <Action Name="End_of_Axis_Movement_entry" Id="{f7223aa0-6f78-4f6c-abda-089ab7bd6b63}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[//stAxesfunctions[iAxisNumber].bJogBackward:=TRUE;
stAxesfunctions[iAxisNumber].bJogForward:=TRUE;]]></ST>
      </Implementation>
    </Action>
    <Action Name="End_of_Axis_Movement_exit" Id="{95218c5b-0d59-45ce-9195-4c82be56d284}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNumber].bMcStop:=FALSE;]]></ST>
      </Implementation>
    </Action>
    <Action Name="End_Position_entry" Id="{40933b29-0850-4ae8-acad-deb697f7deee}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNumber].bJogBackward:=FALSE;
stAxesfunctions[iAxisNumber].bJogForward:=FALSE;
stAxesfunctions[iAxisNumber].bMcMoveAbs:=FALSE;]]></ST>
      </Implementation>
    </Action>
    <Transition Name="EndPosition" Id="{1c50efe7-e6b4-4a38-b275-4c478306b0cc}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[TRUE;]]></ST>
      </Implementation>
    </Transition>
    <Action Name="ErrorMessage_entry" Id="{e8414d3c-c899-4e0b-a850-52f17a69b326}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[fbPrintErrMessageByID(sModuleDescription:=fb_SFC_Cycle.sCycleName,sActErrorID:='113x000x002');
]]></ST>
      </Implementation>
    </Action>
    <Action Name="ErrorMessage2_entry" Id="{bd7e7153-f4cc-4e08-b091-4a029cf86dae}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[fbPrintErrMessageByID(sModuleDescription:=fb_SFC_Cycle.sCycleName,sActErrorID:='113x000x001');]]></ST>
      </Implementation>
    </Action>
    <Action Name="Execution_Test_entry" Id="{9bced4a8-39fa-4b73-96d4-c45c8178f105}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNumber].fPosition:=fRangeToChek+fHomingPositionOffset;
stAxesfunctions[iAxisNumber].fVelocity:=iVelocute;
stAxesfunctions[iAxisNumber].bMcMoveAbs:=TRUE;


]]></ST>
      </Implementation>
    </Action>
    <Action Name="Execution_Test_exit" Id="{8b13f7d6-6892-4892-82b9-b0543cc028ee}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNumber].bMcMoveAbs:=FALSE;]]></ST>
      </Implementation>
    </Action>
    <Action Name="finish_entry" Id="{0977504f-717b-4f41-8203-16402ad991ca}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[bHommingDone:=TRUE;
bExecute:=FALSE;]]></ST>
      </Implementation>
    </Action>
