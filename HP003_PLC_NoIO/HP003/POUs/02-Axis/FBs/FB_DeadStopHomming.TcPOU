    <Transition Name="PosDiff" Id="{42659282-6e7c-4ca3-824a-a5f8d7ff22dc}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[ABS (stAxis[iAxisNumber].NcToPlc.PosDiff) >=0.1
OR
ABS (stAxis[iAxisNumber].NcToPlc.PosDiff) <=-0.1
]]></ST>
      </Implementation>
    </Transition>
    <Transition Name="PosDiff2" Id="{e550f895-197e-4df8-8a9d-15cc78dcd198}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[ABS (stAxis[iAxisNumber].NcToPlc.PosDiff) >=0.2
OR
ABS (stAxis[iAxisNumber].NcToPlc.PosDiff) <=-0.2]]></ST>
      </Implementation>
    </Transition>
    <Transition Name="PosDiffZero" Id="{dec0e5c9-ea75-4c57-862d-8638ef837a7c}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[ABS (stAxis[iAxisNumber].NcToPlc.PosDiff) <0.01
AND
ABS (stAxis[iAxisNumber].NcToPlc.PosDiff) >-0.01
]]></ST>
      </Implementation>
    </Transition>
    <Transition Name="PositioZero" Id="{0b86167b-f14d-4fcc-adbb-fc860711b976}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[abs(stAxesfunctions[iAxisNumber].PFB)<fHomingPositionOffset+0.01; //<0.01;]]></ST>
      </Implementation>
    </Transition>
