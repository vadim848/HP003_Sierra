    </Action>
    <Action Name="Init_exit" Id="{817fd87e-478f-4f75-8bc1-a4cc1e525fb7}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNumber].McResetErr:=TRUE;
Global_Var_AxisInterface.stAxesfunctions[iAxisNumber].fjogVelocity:=iVelocute;
fbMC_Home.Execute:=FALSE;
stAxesfunctions[iAxisNumber].bMcMoveAbs:=FALSE;
stAxesfunctions[iAxisNumber].bJogForward:=FALSE;
stAxesfunctions[iAxisNumber].bJogBackward:=FALSE;
stAxesfunctions[iAxisNumber].bMcReset:=FALSE;

fbEcCoESdoWrite(bExecute:=FALSE);
fbEcCoESdoRead(bExecute:=FALSE);
	
	
]]></ST>
      </Implementation>
    </Action>
    <Transition Name="InTarget" Id="{5019b057-10ab-464b-97c0-065ad666f9ef}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[//p_arr_Axis^[iAxisNumber].arInPos[2,0]
stAxesfunctions[iAxisNumber].PFB>=fRangeToChek+fHomingPositionOffset;]]></ST>
      </Implementation>
    </Transition>
