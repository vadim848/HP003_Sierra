        <ST><![CDATA[stAxesfunctions[iAxisNumber].bMcStop:=TRUE;
stAxesfunctions[iAxisNumber].bJogBackward:=FALSE;
stAxesfunctions[iAxisNumber].bJogForward:=FALSE;

]]></ST>
      </Implementation>
    </Action>
    <Action Name="The_Required_Point_active" Id="{2c6f269a-a2b0-4e1a-b438-060c4798d567}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[IF stAxesfunctions[iAxisNumber].PFB<=iEndPosition+0.01
AND stAxesfunctions[iAxisNumber].PFB>=iEndPosition-0.01 THEN;
	bStepDone:=TRUE;
ELSE;
	bStepDone:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="The_Required_Point_entry" Id="{30605ce4-e283-4373-ab4e-3018466cdc6c}" FolderPath="Actions\">
      <Implementation>
        <ST><![CDATA[stAxesfunctions[iAxisNumber].fPosition:=iEndPosition;
stAxesfunctions[iAxisNumber].fVelocity:=iVelocute;
stAxesfunctions[iAxisNumber].bMcMoveAbs:=TRUE;
]]></ST>
      </Implementation>
    </Action>
    <Action Name="The_Required_Point_exit" Id="{4ade9c71-ebd0-487b-95fa-3fc48c83a586}" FolderPath="Actions\">
