<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.11">
  <POU Name="FB_AX5000_DiagInfo" Id="{7c2f6431-ca7e-4030-b6d7-13ce21d392c2}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_AX5000_DiagInfo
VAR_INPUT
	bStart			:	BOOL; (* while true continue polling DiagNumber*)
	stPlcDriveRef 	:	ST_PlcDriveRef;
END_VAR
VAR_OUTPUT
	bError			:	BOOL;
	stDiag			:	ST_AX5000_DiagInfo;
END_VAR
VAR
	fbDiagMessage	:   FB_SoEReadDiagNumber_ByDriveRef;

	stDriveRef		:	ST_DriveRef;
	initialized		:	BOOL;
	old_iDiagInfo	:	UDINT;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT initialized THEN
	initialize();
    IF (stDriveRef.sNetId <> '') AND (stDriveRef.nSlaveAddr <> 0) THEN
        initialized := TRUE;
    END_IF
END_IF

IF bStart AND initialized THEN
	stDiag.udID := 0;
	fbDiagMessage(
	stDriveRef := stDriveRef,
	bExecute := TRUE,
	tTimeout := DEFAULT_ADS_TIMEOUT,
	iDiagNumber=> stDiag.udID
    );
	IF NOT fbDiagMessage.bBusy THEN
		fbDiagMessage(stDriveRef := stDriveRef, bExecute := FALSE);
		bStart := FALSE;
		bError := (stDiag.udID > 0) AND (stDiag.udID <> 16#D012) AND (stDiag.udID <> 16#D013) AND (stDiag.udID <> 16#D011);
		IF old_iDiagInfo <> stDiag.udID THEN
			old_iDiagInfo := stDiag.udID;
			CASE stDiag.udID OF
				16#D001: 	stDiag.sMsg			    :=	'Esc state: PreOp';
							stDiag.sDescription		:=	'Esc state: PreOp';
							stDiag.sClass			:=	'Class 3: Information';
							stDiag.sReaction		:=	'no';
							stDiag.sType			:=	'Runtime error';
							stDiag.sReset			:=	'A reset is not possible. The drive detected a fatal hardware or software error.';
							stDiag.sCause			:=	'';
							stDiag.sRemedy		    :=	'';
							stDiag.bInfo			:=	FALSE;
							stDiag.bWarning		    :=	FALSE;
							stDiag.bError			:=	TRUE;

				16#D002:	stDiag.sMsg			    :=	'Esc state: Boot';
							stDiag.sDescription		:=	'Esc state: Boot';
							stDiag.sClass			:=	'Class 3: Information';
							stDiag.sReaction		:=	'no';
							stDiag.sType			:=	'Runtime error';
							stDiag.sReset			:=	'A reset is not possible. The drive detected a fatal hardware or software error.';
							stDiag.sCause			:=	'';
							stDiag.sRemedy		    :=	'';
							stDiag.bInfo	    	:=	FALSE;
							stDiag.bWarning		    :=	FALSE;
							stDiag.bError			:=	TRUE;

				16#D003:	stDiag.sMsg			    :=	'Esc state: SafeOp';
							stDiag.sDescription		:=	'Esc state: SafeOp';
							stDiag.sClass			:=	'Class 3: Information';
							stDiag.sReaction		:=	'no';
							stDiag.sType			:=	'Runtime error';
							stDiag.sReset			:=	'A reset is not possible. The drive detected a fatal hardware or software error.';
							stDiag.sCause			:=	'';
							stDiag.sRemedy		    :=	'';
							stDiag.bInfo			:=	FALSE;
							stDiag.bWarning		    :=	FALSE;
							stDiag.bError			:=	TRUE;

				16#D005:	stDiag.sMsg			    :=	'Esc state: Op';
							stDiag.sDescription		:=	'Esc state: Op';
							stDiag.sClass			:=	'Class 3: Information';
							stDiag.sReaction		:=	'no';
							stDiag.sType			:=	'Runtime error';
							stDiag.sReset			:=	'A reset is not possible. The drive detected a fatal hardware or software error.';
							stDiag.sCause			:=	'';
							stDiag.sRemedy		    :=	'';
							stDiag.bInfo			:=	FALSE;
							stDiag.bWarning		    :=	FALSE;
							stDiag.bError			:=	TRUE;

				16#D006:	stDiag.sMsg			    :=	'Esc state: invalid';
							stDiag.sDescription		:=	'Esc state: invalid';
							stDiag.sClass			:=	'Class 3: Information';
							stDiag.sReaction		:=	'no';
							stDiag.sType			:=	'Runtime error';
							stDiag.sReset			:=	'A reset is not possible. The drive detected a fatal hardware or software error.';
							stDiag.sCause			:=	'';
							stDiag.sRemedy		    :=	'';
							stDiag.bInfo	    	:=	FALSE;
							stDiag.bWarning		    :=	FALSE;
							stDiag.bError			:=	TRUE;

