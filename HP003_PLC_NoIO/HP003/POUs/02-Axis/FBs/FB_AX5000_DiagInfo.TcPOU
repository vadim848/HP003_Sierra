							stDiag.bWarning		:=	FALSE;
							stDiag.bError			:=	TRUE;

				16#D102:	stDiag.sMsg			:=	'Safety lockout active.';
							stDiag.sDescription		:=	'Safety lockout active.';
							stDiag.sClass			:=	'Class 3: Information';
							stDiag.sReaction		:=	'no';
