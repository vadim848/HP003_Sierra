							stDiag.sReaction		:=	'no';
							stDiag.sType			:=	'Runtime error';
							stDiag.sReset			:=	'A reset is not possible. The drive detected a fatal hardware or software error.';
							stDiag.sCause			:=	'';
							stDiag.sRemedy		    :=	'';
							stDiag.bInfo			:=	FALSE;
							stDiag.bWarning		    :=	FALSE;
							stDiag.bError			:=	TRUE;

				16#D011:	stDiag.sMsg			    :=	'Axis state machine: Control section ready';
							stDiag.sDescription		:=	'Axis state machine: Control section ready';
							stDiag.sClass			:=	'Class 3: Information';
							stDiag.sReaction		:=	'no';
							stDiag.sType			:=	'Runtime error';
							stDiag.sReset			:=	'A reset is not possible. The drive detected a fatal hardware or software error.';
							stDiag.sCause			:=	'';
							stDiag.sRemedy	    	:=	'';
							stDiag.bInfo			:=	TRUE;
