          </TypeList>
        </XmlArchive>
      </ObjectProperties>
    </Action>
    <Action Name="_aStandby_entry" Id="{f35835ad-a084-41e8-ab10-5b42bf95f45a}">
      <Implementation>
        <ST><![CDATA[bNextStep := FALSE;]]></ST>
      </Implementation>
      <ObjectProperties>
