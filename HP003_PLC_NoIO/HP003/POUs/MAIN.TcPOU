      </ObjectProperties>
    </Action>
    <Action Name="_aStandby_active" Id="{4c691c8a-74a3-4ede-96f8-12eb64332c76}">
      <Implementation>
        <ST><![CDATA[IF bITMStart THEN
	bNextStep:= TRUE;
END_IF]]></ST>
      </Implementation>
      <ObjectProperties>
        <XmlArchive>
          <Data>
            <o xml:space="preserve" t="ActionObjectDuplicationModeProperty">
              <v n="Embedded">true</v>
