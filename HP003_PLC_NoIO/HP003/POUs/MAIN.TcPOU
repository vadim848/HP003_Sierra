      </ObjectProperties>
    </Action>
    <Action Name="_aPowerOn_active" Id="{418f2a0c-d0cf-42c8-9771-11ec51a42d4e}">
      <Implementation>
        <ST><![CDATA[itmAxFunc.bMcPower := TRUE;

IF itmAxFunc.stStatus.Error THEN
	errStr:= UDINT_TO_STRING(itmAxFunc.stStatus.ErrorID);
END_IF
]]></ST>
      </Implementation>
      <ObjectProperties>
        <XmlArchive>
          <Data>
            <o xml:space="preserve" t="ActionObjectDuplicationModeProperty">
              <v n="Embedded">true</v>
            </o>
          </Data>
