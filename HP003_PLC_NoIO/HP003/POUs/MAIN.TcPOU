            <Type n="Boolean">System.Boolean</Type>
          </TypeList>
        </XmlArchive>
      </ObjectProperties>
    </Action>
    <Action Name="_aPowerOn_entry" Id="{a60dea07-68e1-4db5-81d7-dddb66b1931a}">
      <Implementation>
        <ST><![CDATA[bNextStep := FALSE;]]></ST>
      </Implementation>
      <ObjectProperties>
        <XmlArchive>
          <Data>
