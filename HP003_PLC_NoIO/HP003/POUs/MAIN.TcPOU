<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="MAIN" Id="{e275a364-5e77-4749-8ef4-faa0b25b4f67}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM MAIN
VAR
	IOs	  		: str_IOs;
	itmAxFunc	: ST_Axesfunctions;
	impAxFunc	: ST_Axesfunctions;
	pidAxFunc	: ST_Axesfunctions;
	latAxFunc	: ST_Axesfunctions;
	jigParams	: MotorParams_typ;
	fb_ITM		: FB_Axisfunctions;
	fb_PID		: FB_Axisfunctions;
	fb_IMP		: FB_Axisfunctions;
	fb_LatSkew	: FB_Axisfunctions;
	
	//buttons for both activation/release front and rear
	bGroupT1Act		: BOOL := FALSE;
	bGroupT1Rel		: BOOL := FALSE;
	bGroupT2Act 	: BOOL := FALSE;
	bGroupT2Rel		: BOOL := FALSE;
	bGroupTensAct 	: BOOL := FALSE;
	bGroupTensRel	: BOOL := FALSE;
	 
	bITMStart		: BOOL;	
	bIMPStart		: BOOL;
	bPIDStart		: BOOL;
	bITMStop		: BOOL;	
	bIMPStop		: BOOL;
	bPIDStop		: BOOL;
	bNextStep		: BOOL;
	errStr			: STRING;
	
	itmState		: INT;
	impState		: INT;
	pidState		: INT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[act_IO_Mapping();
act_StateMachineSFC();

fb_ITM(stAxFunctions:= ADR(itmAxFunc), stAxis := ADR(GVL_AXES.ax_ITM));
fb_IMP(stAxFunctions:= ADR(impAxFunc), stAxis := ADR(GVL_AXES.ax_IMP));
fb_PID(stAxFunctions:= ADR(pidAxFunc), stAxis := ADR(GVL_AXES.ax_PID));
fb_LatSkew(stAxFunctions:= ADR(latAxFunc), stAxis := ADR(GVL_AXES.ax_LatSkew));

]]></ST>
    </Implementation>
    <Action Name="_aHoming_active" Id="{66b5584a-5b9e-48d9-8709-40c4b246a144}">
      <Implementation>
        <ST><![CDATA[//itmAxFunc.HomingMode	:= HomeM
itmAxFunc.bMcHome 		:= TRUE;]]></ST>
      </Implementation>
      <ObjectProperties>
        <XmlArchive>
          <Data>
            <o xml:space="preserve" t="ActionObjectDuplicationModeProperty">
              <v n="Embedded">true</v>
            </o>
          </Data>
