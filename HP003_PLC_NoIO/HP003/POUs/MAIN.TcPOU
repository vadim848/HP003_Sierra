            <Type n="ActionObjectDuplicationModeProperty">{6a58c9ae-b0e2-4127-8d9c-cbfc36a09580}</Type>
            <Type n="Boolean">System.Boolean</Type>
          </TypeList>
        </XmlArchive>
      </ObjectProperties>
    </Action>
    <Action Name="_aInit_active" Id="{237d82c0-ffab-4771-af16-978dfcc58b6e}">
      <Implementation>
        <ST><![CDATA[bNextStep				:= FALSE;
itmAxFunc.bAxisEnabled	:= FALSE; 
itmAxFunc.bMcHome		:= FALSE;
itmAxFunc.bMcMoveVelo	:= FALSE;


IF itmAxFunc.stStatus.Disabled AND NOT itmAxFunc.stStatus.Error THEN
	bNextStep := TRUE; 
END_IF]]></ST>
      </Implementation>
      <ObjectProperties>
        <XmlArchive>
          <Data>
            <o xml:space="preserve" t="ActionObjectDuplicationModeProperty">
              <v n="Embedded">true</v>
            </o>
          </Data>
          <TypeList>
            <Type n="ActionObjectDuplicationModeProperty">{6a58c9ae-b0e2-4127-8d9c-cbfc36a09580}</Type>
            <Type n="Boolean">System.Boolean</Type>
          </TypeList>
        </XmlArchive>
      </ObjectProperties>
    </Action>
    <Action Name="_aMoveVelocity_active" Id="{b73dc277-e5af-49be-bf1c-f9a2ed93ec26}">
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
      <ObjectProperties>
        <XmlArchive>
