              <v n="TextID">"1910"</v>
              <v n="TextDefault">"TYPE MC_BufferMode :
 (
	MC_Aborting		:= 16#00,
	MC_Buffered		:= 16#01,
	MC_BlendingLow		:= 16#12,
	MC_BlendingPrevious	:= 16#13,
	MC_BlendingNext		:= 16#14,
	MC_BlendingHigh		:= 16#15
 );
END_TYPE"</v>
