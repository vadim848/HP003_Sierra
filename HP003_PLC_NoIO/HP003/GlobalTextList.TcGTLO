            <o>
              <v n="TextID">"1705"</v>
              <v n="TextDefault">"TYPE MC_Direction :
(
	MC_Positive_Direction := 1,
	MC_Shortest_Way ,
	MC_Negative_Direction,
	MC_Current_Direction
);
END_TYPE"</v>
